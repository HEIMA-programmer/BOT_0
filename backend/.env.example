# Flask Configuration
FLASK_SECRET_KEY=your-secret-key-here
FLASK_ENV=development
DATABASE_URL=sqlite:///app.db

# OpenAI API (for quiz generation and speaking feedback)
OPENAI_API_KEY=your-openai-api-key

# Azure Speech Service (for pronunciation assessment)
AZURE_SPEECH_KEY=your-azure-speech-key
AZURE_SPEECH_REGION=eastasia

# Anthropic Claude API (for content scoring)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Google Gemini API (for AI voice conversations)
GOOGLE_API_KEY=your-google-api-key

# DeepSeek API (for conversation scoring)
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_API_URL=https://api.deepseek.com

# Agora RTC (for real-time video/audio rooms)
AGORA_APP_ID=your-agora-app-id
AGORA_APP_CERTIFICATE=your-agora-app-certificate

# CORS (comma-separated origins for production)
CORS_ORIGINS=http://localhost:5173
